{
    "manifest_version": 3,
    "name": "Tab Wind Command",
    "version": "1.0.0",
    "description": "Fast tab search and AI-powered switching command palette.",
    "permissions": [
        "tabs",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "src/background.ts"
    },
    "action": {
        "default_title": "Search Tabs",
        "default_icon": "icons/icon.png"
    },
    "icons": {
        "16": "icons/icon.png",
        "32": "icons/icon.png",
        "48": "icons/icon.png",
        "128": "icons/icon.png"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/content.ts"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "ai-bridge.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "commands": {
        "toggle-search": {
            "suggested_key": {
                "default": "Ctrl+Shift+L",
                "mac": "Command+Shift+L"
            },
            "description": "Toggle Tab Search"
        }
    }
}